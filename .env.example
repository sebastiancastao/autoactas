# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Resend (server-side email)
RESEND_API_KEY=
RESEND_DEFAULT_FROM=

# Cron / API secrets
CRON_SECRET=
EVENT_REMINDER_SECRET=
EVENT_REMINDER_WEBHOOK_URL=

# Gravity Forms lead sync (optional)
# Full submissions endpoint, e.g. https://example.com/wp-json/gf/v2/forms/1/submissions
GRAVITY_FORMS_SUBMISSIONS_URL=
# Optional Basic Auth for WordPress / Gravity Forms API
GRAVITY_FORMS_BASIC_AUTH_USER=
GRAVITY_FORMS_BASIC_AUTH_PASSWORD=
# Optional timeout in milliseconds (default: 12000)
GRAVITY_FORMS_TIMEOUT_MS=12000
# Optional JSON map: Gravity input key -> lead payload path
# Example: {"input_1":"numeroProceso","input_2":"deudor.nombre","input_3":"deudor.email"}
GRAVITY_FORMS_FIELD_MAP=
# Optional JSON object of fixed Gravity input values
# Example: {"input_10":"AutoActas"}
GRAVITY_FORMS_STATIC_VALUES=

# Google Drive (server-side, service account)
# Share the target folder with the service account email.
GOOGLE_DRIVE_CLIENT_EMAIL=
# Private key (replace line breaks with \n)
GOOGLE_DRIVE_PRIVATE_KEY=
# Optional: upload into this folder
GOOGLE_DRIVE_FOLDER_ID=
# Optional: grant Writer permission to this email after upload
GOOGLE_DRIVE_SHARE_WITH_EMAIL=
# Optional: public sharing. Values: `anyone_reader` (default), `anyone_writer`, `off`
GOOGLE_DRIVE_PUBLIC_ACCESS=anyone_reader

# Supabase Storage for generated documents and uploads
# Bucket will be created automatically if missing.
SUPABASE_STORAGE_DOCUMENTS_BUCKET=documentos

# Google Calendar / Google Meet (server-side)
# Reuses GOOGLE_DRIVE_CLIENT_EMAIL / GOOGLE_DRIVE_PRIVATE_KEY if omitted.
GOOGLE_CALENDAR_ID=
# Recommended for Google Meet + attendee invites in Google Workspace.
GOOGLE_CALENDAR_IMPERSONATE_USER_EMAIL=
# Optional overrides if Calendar uses a different service account.
GOOGLE_CALENDAR_CLIENT_EMAIL=
GOOGLE_CALENDAR_PRIVATE_KEY=
# Optional duration in minutes when an event has start time but no explicit end.
GOOGLE_CALENDAR_DEFAULT_DURATION_MINUTES=60

# Google OAuth for personal Gmail / user calendars
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Exact redirect URI registered in Google Cloud OAuth credentials.
# Example: http://localhost:3000/api/google-calendar/oauth/callback
GOOGLE_OAUTH_REDIRECT_URI=
